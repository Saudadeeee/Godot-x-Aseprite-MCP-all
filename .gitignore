# ============================================================
# Godot x Aseprite MCP — root .gitignore
# ============================================================

# ============================================================
# Node.js (Godot-MCP server)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# TypeScript build output
Godot-MCP/server/dist/

# ============================================================
# Python (aseprite-mcp)
# ============================================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.Python

# uv
.uv/

# ============================================================
# Godot Engine
# ============================================================
# Editor-generated cache and import data
.godot/
*.import
*.translation

# Export output
export/
*.apk
*.aab
*.ipa
*.exe
*.x86_64
*.dmg
*.zip
*.tar.gz

# ============================================================
# Aseprite
# ============================================================
# Generated sprite files used for testing
*.aseprite
*.ase

# Exported art (these should live in the game project, not here)
*.png
*.gif
*.webp

# ============================================================
# Environment & secrets
# ============================================================
.env
.env.local
.env.*.local
*.env

# ============================================================
# AI agent local settings (contain personal paths/permissions)
# ============================================================
.claude/
.cursor/
.aider*
.continue/

# ============================================================
# IDE & editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# OS
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================================
# Logs & temp
# ============================================================
logs/
*.log
tmp/
temp/
.cache/
